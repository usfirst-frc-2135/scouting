<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- start "START CLIMB" layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:background="@drawable/rounded_rect"
                android:backgroundTint="#adbba2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="@string/start_climbing"
                    android:textColor="@color/customTextPrimary"
                    android:textSize="@dimen/font_medium"
                    android:textStyle="bold" />

                <!-- start "START CLIMB RADIO BUTTONS" layout-->
                <RadioGroup
                    android:id="@+id/start_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_rect_bottom"
                    android:backgroundTint="#c1cbb8"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/start_none"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/n_a"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/start_before"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/before"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/start_bell"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/bell"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/start_ten"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/at_10s_left"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/start_less"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/less_than_10s"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />
                </RadioGroup>
                <!-- end START CLIMB RADIO BUTTONS layout-->

            </LinearLayout>
            <!-- end START CLIMB layout -->

            <!-- start CLIMB layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/rounded_rect"
                android:backgroundTint="#93A685"
                android:orientation="vertical"
                android:paddingTop="11dp">

                <!--start layout that holds first image-->
                <LinearLayout
                    android:id="@+id/imageOne"
                    android:layout_width="wrap_content"
                    android:layout_height="230dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/tower_angle_one">

                    <!-- start CLIMB LEVEL TEXT layout-->
                    <LinearLayout
                        android:layout_width="130dp"
                        android:layout_height="65dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/rounded_rect"
                        android:backgroundTint="#f3d8ea">

                        <TextView
                            android:id="@+id/Climb_title"
                            android:layout_width="115dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="7dp"
                            android:text="@string/climb_level"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <!-- end CLIMB LEVEL TEXT layout-->

                    <!-- start CLIMB LEVEL RADIO BUTTONS layout-->
                    <RadioGroup
                        android:id="@+id/endgame_level_climb_group"
                        android:layout_width="match_parent"
                        android:layout_height="230dp"
                        android:layout_marginTop="0dp"
                        android:orientation="vertical"
                        android:paddingTop="20dp">

                        <RadioButton
                            android:id="@+id/endgame_level_na"
                            android:layout_width="70dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginTop="1dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#f3d8ea"
                            android:buttonTint="#db8ac1"
                            android:text="@string/n_a"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_level_three"
                            android:layout_width="65dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="240dp"
                            android:layout_marginTop="27dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#f3d8ea"
                            android:buttonTint="#db8ac1"
                            android:text="@string/level_three"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_level_two"
                            android:layout_width="65dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="240dp"
                            android:layout_marginTop="40dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#f3d8ea"
                            android:buttonTint="#db8ac1"
                            android:text="@string/level_two"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_level_one"
                            android:layout_width="65dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="240dp"
                            android:layout_marginTop="30dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#f3d8ea"
                            android:buttonTint="#db8ac1"
                            android:text="@string/level_one"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                    </RadioGroup>
                    <!-- end CLIMB LEVEL RADIO BUTTONS layout-->

                </LinearLayout>
                <!--end layout that holds first image-->

                <!--start layout that holds second image-->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="100dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/tower_angle_two">

                    <!-- start CLIMB POSITION TEXT layout-->
                    <LinearLayout
                        android:layout_width="130dp"
                        android:layout_height="65dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/rounded_rect"
                        android:backgroundTint="#C7CDD6">

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="7dp"
                            android:text="@string/climb_position"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                    </LinearLayout>
                    <!-- end CLIMB POSITION TEXT layout-->

                    <!-- start CLIMB POSITION RADIO BUTTONS section-->
                    <RadioGroup
                        android:id="@+id/endgame_climb_buttons"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:buttonTint="#717982"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/endgame_climb_na"
                            android:layout_width="70dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginTop="25dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/n_a"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_climb_back"
                            android:layout_width="50dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="90dp"
                            android:layout_marginTop="30dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/back"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_climb_left"
                            android:layout_width="50dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="0dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/left"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_climb_front"
                            android:layout_width="50dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="-5dp"
                            android:layout_marginTop="30dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/front"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                        <RadioButton
                            android:id="@+id/endgame_climb_right"
                            android:layout_width="50dp"
                            android:layout_height="25dp"
                            android:layout_marginStart="-10dp"
                            android:layout_marginTop="0dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#818A95"
                            android:text="@string/right"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_small" />

                    </RadioGroup>
                    <!-- end CLIMB POSITION RADIO BUTTONS section-->

                </LinearLayout>
                <!--end layout that holds second image-->

            </LinearLayout>
            <!--end CLIMB section-->

            <!-- start DIED layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_rect"
                android:backgroundTint="#b2538e"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:layout_marginEnd="5dp"
                    android:text="@string/died"
                    android:textColor="@color/customTextPrimary"
                    android:textSize="@dimen/font_medium"
                    android:textStyle="bold" />
                <!-- start DIED RADIO BUTTONS  -->
                <RadioGroup
                    android:id="@+id/died_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_rect_bottom"
                    android:backgroundTint="#c277a6"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/died_none"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/n_a"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/died_most"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/most"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/died_min"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/more_than_1min"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/died_thirty"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/more_than_30s"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/died_tt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/between_15s_30s"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />

                    <RadioButton
                        android:id="@+id/no_show"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/customTextPrimary"
                        android:text="@string/no_show"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium" />
                </RadioGroup>
                <!-- end DIED RADIO BUTTONS  -->

            </LinearLayout>
            <!-- end DIED section -->

            <!-- COMMENTS start -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="7dp">

                <TextView
                    android:id="@+id/comments_title"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="@string/comments"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/font_large" />

                <EditText
                    android:id="@+id/comments"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:autofillHints="none"
                    android:hint="@string/enter_comments_here"
                    android:inputType="text"
                    android:maxLength="400"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintColor"
                    android:textSize="@dimen/font_medium">

                </EditText>

            </LinearLayout>
            <!-- COMMENTS end-->

            <android.widget.Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/gen_QR"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/rounded_rect"
                    android:backgroundTint="#3F98B5"
                    android:contentDescription="@string/qr_code_image"
                    android:focusable="true"
                    android:src="@drawable/qr_code_icon"
                    android:textColor="#3F51B5" />

                <ImageButton
                    android:id="@+id/gen_QR_disabled"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/rounded_rect"
                    android:backgroundTint="#6e848d"
                    android:contentDescription="@string/qr_code_image"
                    android:focusable="true"
                    android:src="@drawable/qr_code_icon"
                    android:textColor="#3F51B5" />

                <android.widget.Space
                    android:layout_width="90dp"
                    android:layout_height="match_parent" />

                <Button
                    android:id="@+id/endgame_done_button"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="80dp"
                    android:layout_toEndOf="@id/gen_QR"
                    android:background="@drawable/rounded_rect"
                    android:backgroundTint="#FFC107"
                    android:focusable="true"
                    android:text="@string/done"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/font_huge" />

                <Button
                    android:id="@+id/endgame_done_button_disabled"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="80dp"
                    android:layout_toEndOf="@id/gen_QR"
                    android:background="@drawable/rounded_rect"
                    android:backgroundTint="#b19769"
                    android:focusable="true"
                    android:text="@string/done"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/font_huge" />

            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
