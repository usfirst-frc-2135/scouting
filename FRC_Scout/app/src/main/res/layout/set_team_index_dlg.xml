<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="30dp"
        android:paddingRight="30dp">

        <TextView
            android:id="@+id/set_team_index_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/set_the_team_index_to_use" />

        <EditText
            android:id="@+id/set_team_index_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ems="10"
            android:autofillHints="team index"
            android:hint="@string/team_index"
            android:inputType="text"
            android:paddingTop="25dp" />

        <TextView
            android:id="@+id/team_index_err"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/valid_values" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
