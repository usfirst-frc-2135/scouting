<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/set_team_index_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/set_team_index_header_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/set_the_team_index_to_use"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium" />

    <!-- start Team index dropdown layout -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/set_team_index_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/set_team_index_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:hint="@string/team_index" />
    </com.google.android.material.textfield.TextInputLayout>
    <!-- end Team index dropdown layout -->

</LinearLayout>
