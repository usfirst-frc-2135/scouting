<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/scouting_scroll_bottom_nav__margin">

        <!-- start Teleop fragment main layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: GAME PIECE MANIPULATION -->
            <!-- start GAME PIECE MANIPULATION card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#CACFF9"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- start HOPPER +/- BUTTONS layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/teleop_hopper_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/hoppers_shot"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/teleop_hopper_decr_button"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="70dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#017371"
                            android:text="@string/decrease"
                            android:textAlignment="center"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/teleop_hopper_total_text"
                            android:layout_width="70dp"
                            android:layout_height="match_parent"
                            android:textAlignment="center"
                            android:text="@string/hopper_count_total"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_large" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/teleop_hopper_incr_button"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#017371"
                            android:text="@string/increase"
                            android:textAlignment="center"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                    </LinearLayout>
                    <!-- end HOPPER +/- BUTTONS layout -->

                    <!-- start HOPPER ACCURACY RATING layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#DFE2FB"
                        android:orientation="vertical"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/teleop_accuracy_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/accuracy_rate"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/teleop_accuracy_radio_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_na"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/n_a"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_most"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/most"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_three_fourths"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/three_qtr"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_half"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/one_half"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_quarter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/one_qtr"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_few"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/few"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_accuracy_none"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#8957A1"
                                android:text="@string/none"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />
                        </RadioGroup>
                    </LinearLayout>
                    <!-- end HOPPER ACCURACY RATING layout -->

                    <!-- start INTAKE AND SHOOT CHIP layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#EAECFD"
                        android:orientation="horizontal"
                        android:padding="@dimen/section_padding">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/teleop_intake_shoot_chip"
                            style="@style/CustomChipStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/intake_while_shooting" />

                    </LinearLayout>
                    <!--end INTAKE AND SHOOT CHIP layout -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end GAME PIECE MANIPULATION card layout -->

            <!-- Section: PASSING SECTION -->
            <!-- start PASSING SECTION card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#87CEEB"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- start PASSING FROM layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/teleop_passing_zone_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/passing_from_zone"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <!-- start PASSING ZONE CHIPS layout -->
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/teleop_pass_zone_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            app:chipSpacingHorizontal="12dp">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/teleop_pass_nz_chip"
                                style="@style/CustomChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/neutral_zone" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/teleop_pass_az_chip"
                                style="@style/CustomChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alliance_zone" />

                        </com.google.android.material.chip.ChipGroup>
                        <!-- end PASSING ZONE CHIPS layout -->

                    </LinearLayout>
                    <!-- end PASSING FROM layout -->

                    <!-- start PASSING EFFECTIVENESS RATING layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#ADD8EF"
                        android:orientation="vertical"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/teleop_passing_rate_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/passing_rate"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/teleop_passing_rate_radio_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:orientation="horizontal">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_passing_rate_na"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#051650"
                                android:text="@string/n_a"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_passing_rate_low"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#051650"
                                android:text="@string/low"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_passing_rate_medium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#051650"
                                android:text="@string/medium"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_passing_rate_large"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#051650"
                                android:text="@string/large"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/teleop_passing_rate_tons"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#051650"
                                android:text="@string/tons"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />
                        </RadioGroup>

                    </LinearLayout>
                    <!-- end PASSING EFFECTIVENESS RATING layout -->

                    <!-- start HERDING FUEL CHIP layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F0FFFF"
                        android:orientation="horizontal"
                        android:padding="@dimen/section_padding">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/teleop_herded_fuel_chip"
                            style="@style/CustomChipStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/herded_lots_of_fuel" />
                    </LinearLayout>
                    <!--end HERDING FUEL CHIP layout -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end PASSING SECTION card layout -->

            <!-- Section: DEFENSE SECTION -->
            <!-- start DEFENSE SECTION card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#adc7ee"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/section_padding">

                    <TextView
                        android:id="@+id/teleop_defense_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/defense"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium"
                        android:textStyle="bold" />

                    <!-- start DEFENSE RADIO BUTTONS layout -->
                    <RadioGroup
                        android:id="@+id/teleop_defense_radio_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_na"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/n_a"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_low"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/low"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_med_low"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/med_low"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/medium"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_med_high"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/med_high"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_defense_high"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/high"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />
                    </RadioGroup>
                    <!-- end DEFENSE RADIO BUTTONS layout -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end DEFENSE SECTION card layout -->

            <!-- Section: DRIVER ABILITY -->
            <!-- start DRIVER ABILITY card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#9aa3f2"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/section_padding">

                    <TextView
                        android:id="@+id/teleop_driving_ability_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/driving_ability"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium"
                        android:textStyle="bold" />

                    <!-- start DRIVING ABILITY RADIO BUTTONS layout -->
                    <RadioGroup
                        android:id="@+id/teleop_driving_ability_radio_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_na"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/n_a"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_slow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/slow"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_jerky"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/jerky"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_avg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/avg"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_fast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/fast"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/teleop_driving_ability_elite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#051650"
                            android:text="@string/elite"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />
                    </RadioGroup>
                    <!-- end DRIVING ABILITY RADIO BUTTONS layout -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end DRIVER ABILITY card layout -->

            <!-- start PHOTO layout -->
            <!-- Section: PHOTO -->
            <LinearLayout
                android:id="@+id/teleop_photo_container"
                android:layout_width="589dp"
                android:layout_height="186dp"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/card_margin"
                android:background="@drawable/rebuilt_logo"
                android:orientation="horizontal">

            </LinearLayout>
            <!-- end PHOTO card layout -->

        </LinearLayout>
        <!-- end Teleop fragment main layout -->

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
