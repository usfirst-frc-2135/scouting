<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- start Main container layout -->
    <LinearLayout
        android:id="@+id/match_filter_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/match_filter_instructions_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_instructions"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:layout_marginBottom="24dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- start Event Code Filter layout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/match_filter_event_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:startIconDrawable="@android:drawable/ic_menu_today"
            app:startIconContentDescription="@string/event_icon_desc"
            app:endIconMode="clear_text"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp">

            <AutoCompleteTextView
                android:id="@+id/match_filter_event_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/event_code"
                android:inputType="none"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />
        </com.google.android.material.textfield.TextInputLayout>
        <!-- end Event Code Filter layout -->

        <!-- start Match Number Filter layout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/match_filter_match_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:startIconDrawable="@android:drawable/ic_menu_edit"
            app:startIconContentDescription="@string/match_icon_desc"
            app:endIconMode="clear_text"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/match_filter_match_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/match_number"
                android:inputType="text"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />
        </com.google.android.material.textfield.TextInputLayout>
        <!-- end Match Number Filter layout -->

        <!-- start Team Filter layout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/match_filter_team_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:startIconDrawable="@android:drawable/ic_menu_info_details"
            app:startIconContentDescription="@string/team_icon_desc"
            app:endIconMode="clear_text"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp">

            <AutoCompleteTextView
                android:id="@+id/match_filter_team_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/team_number"
                android:inputType="none"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />
        </com.google.android.material.textfield.TextInputLayout>
        <!-- end Team Filter layout -->

        <!-- start Scout Filter layout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/match_filter_scout_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconContentDescription="@string/scout_icon_desc"
            app:endIconMode="clear_text"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp">

            <AutoCompleteTextView
                android:id="@+id/match_filter_scout_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/scout_name"
                android:inputType="none"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />
        </com.google.android.material.textfield.TextInputLayout>
        <!-- end Scout Filter layout -->

    </LinearLayout>
    <!-- end Main container layout -->
</ScrollView>
