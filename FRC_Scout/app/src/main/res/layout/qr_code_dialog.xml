<?xml version="1.0" encoding="utf-8"?>
<!-- start QR code dialog layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- start QR card layout -->
    <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:contentPadding="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/qr_dialog_image"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/qr_code_image"
            android:scaleType="fitCenter" />
    </com.google.android.material.card.MaterialCardView>
    <!-- end QR card layout -->

    <TextView
        android:id="@+id/qr_dialog_data_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAlignment="center"
        android:textColor="@color/textSecondary"
        android:textSize="@dimen/font_tiny"
        android:fontFamily="monospace" />

</LinearLayout>
<!-- end QR code dialog layout -->
