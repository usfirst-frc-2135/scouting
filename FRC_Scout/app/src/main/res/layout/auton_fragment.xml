<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/scouting_scroll_bottom_nav__margin">

        <!-- start Autonomous fragment main layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: PRELOAD -->
            <!-- start PRELOAD card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#719da9"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- start PRELOAD CHECKBOX layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/auton_preload_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/preload_title"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/auton_preload_chip"
                            style="@style/CustomChipStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:text="@string/shot_preloaded_fuel" />
                    </LinearLayout>
                    <!-- end PRELOAD CHECKBOX layout -->

                    <!-- start PRELOAD ACCURACY layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#8DB0BA"
                        android:orientation="vertical"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/auton_preload_accuracy_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/preload_accuracy_rate"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <!-- start PRELOAD RADIO BUTTONS layout -->
                        <RadioGroup
                            android:id="@+id/auton_preload_accuracy_radio_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:orientation="horizontal">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_no"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/n_a"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/all"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_most"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/most"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_half"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/half"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_few"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/some"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_preload_accuracy_none"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#354c54"
                                android:text="@string/none"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />
                        </RadioGroup>
                        <!-- end PRELOAD RADIO BUTTONS layout -->

                    </LinearLayout>
                    <!-- end PRELOAD ACCURACY layout -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end PRELOAD card layout -->

            <!-- Section: HOPPER -->
            <!-- start HOPPER card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#EE965F"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- start HOPPER +/- BUTTONS layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/auton_hopper_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/hoppers_shot"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/auton_hopper_decr_button"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="70dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#c64e34"
                            android:text="@string/decrease"
                            android:textAlignment="center"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/auton_hopper_total_text"
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:text="@string/hopper_count_total"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_large" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/auton_hopper_incr_button"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#c64e34"
                            android:text="@string/increase"
                            android:textAlignment="center"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                    </LinearLayout>
                    <!-- end HOPPER +/- BUTTONS layout -->

                    <!-- start HOPPER ACCURACY layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F0A271"
                        android:orientation="vertical"
                        android:padding="@dimen/section_padding">

                        <TextView
                            android:id="@+id/auton_accuracy_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/accuracy_rate"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />

                        <!-- start HOPPER ACCURACY RADIO BUTTONS layout -->
                        <RadioGroup
                            android:id="@+id/auton_accuracy_radio_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_na"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:buttonTint="#c64e34"
                                android:text="@string/n_a"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_most"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c64e34"
                                android:text="@string/most"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_three_fourths"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c64e34"
                                android:text="@string/three_qtr"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_half"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c45120"
                                android:text="@string/one_half"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_quarter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c45120"
                                android:text="@string/one_qtr"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_large" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_few"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c45120"
                                android:text="@string/few"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/auton_accuracy_none"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:buttonTint="#c45120"
                                android:text="@string/none"
                                android:textColor="@color/customTextPrimary"
                                android:textSize="@dimen/font_medium" />
                        </RadioGroup>
                        <!-- end HOPPER ACCURACY RADIO BUTTONS layout -->
                    </LinearLayout>
                    <!-- end HOPPER ACCURACY layout -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end HOPPER card layout -->

            <!-- Section: FUEL -->
            <!-- start FUEL card layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#D48C74"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/section_padding">

                    <TextView
                        android:id="@+id/auton_fuel_source_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/fuel_source"
                        android:textColor="@color/customTextPrimary"
                        android:textSize="@dimen/font_medium"
                        android:textStyle="bold" />

                    <!-- start FUEL CHIPS layout -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/auton_az_chip"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/alliance_zone" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/auton_depot_chip"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="@string/depot" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/auton_outpost_chip"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="@string/outpost" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/auton_nz_chip"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="@string/neutral_zone" />

                    <!-- end FUEL CHIPS layout -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end FUEL card layout -->

            <!-- Section: CLIMB -->
            <!-- start CLIMB card layout -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/auton_climb_position"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                android:layout_marginHorizontal="@dimen/card_margin"
                app:cardBackgroundColor="#93A685"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="330dp"
                    android:orientation="horizontal">

                    <!-- start CLIMB POSITION title layout -->
                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="65dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/rounded_rect"
                        android:backgroundTint="#C7CDD6">

                        <TextView
                            android:id="@+id/auton_climb_label"
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="7dp"
                            android:text="@string/climb_position"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <!-- end CLIMB POSITION title layout -->

                    <!-- start CLIMB POSITION RADIO BUTTONS layout -->
                    <RadioGroup
                        android:id="@+id/auton_climb_radio_group"
                        android:layout_width="430dp"
                        android:layout_height="330dp"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/rebuilt_tower_angle_full"
                        android:buttonTint="#717982"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/auton_climb_na"
                            android:layout_width="80dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="0dp"
                            android:layout_marginTop="23dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/n_a"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/auton_climb_back"
                            android:layout_width="55dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="115dp"
                            android:layout_marginTop="265dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/back"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/auton_climb_left"
                            android:layout_width="55dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="0dp"
                            android:layout_marginTop="195dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/left"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/auton_climb_front"
                            android:layout_width="55dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="15dp"
                            android:layout_marginTop="265dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/front"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/auton_climb_right"
                            android:layout_width="55dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="-35dp"
                            android:layout_marginTop="140dp"
                            android:background="@drawable/rounded_rect"
                            android:backgroundTint="#C7CDD6"
                            android:buttonTint="#717982"
                            android:text="@string/right"
                            android:textColor="@color/customTextPrimary"
                            android:textSize="@dimen/font_medium" />

                    </RadioGroup>
                    <!-- end CLIMB POSITION RADIO BUTTONS layout -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- end CLIMB card layout -->

        </LinearLayout>
        <!-- end Autonomous fragment main layout -->

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
