<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scouting_activity_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ScoutingActivity">

    <!-- start AppBar layout -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/scouting_activity_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/scouting_activity_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:titleTextColor="@android:color/white"
            app:subtitleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>
    <!-- end AppBar layout -->

    <!-- start Fragment container layout -->
    <FrameLayout
        android:id="@+id/scouting_activity_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />
    <!-- end Fragment container layout -->

    <!-- start Bottom navigation layout -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/scouting_activity_nav_view"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/bottomColor"
        app:menu="@menu/bottom_nav_menu" />
    <!-- end Bottom navigation layout -->

</androidx.coordinatorlayout.widget.CoordinatorLayout>
